# ===== PHASE 1 PROVIDERS (Currently Supported) =====

# Gemini API (Google)
# Get key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY="paste_your_gemini_key_here"

# DeepSeek API
# Get key from: https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY="paste_your_deepseek_key_here"

# Local Ollama (100% FREE - No API key needed!)
# Install from: https://ollama.ai
# Run with: ollama serve
VITE_OLLAMA_URL="http://localhost:11434"
VITE_OLLAMA_MODEL="deepseek-r1"

# ===== PHASE 2 PROVIDERS (Coming Soon) =====
# Uncomment and add keys when available

# ChatGPT / OpenAI
# VITE_CHATGPT_API_KEY="paste_your_openai_key_here"

# Claude / Anthropic
# VITE_CLAUDE_API_KEY="paste_your_anthropic_key_here"

# Grok / xAI
# VITE_GROK_API_KEY="paste_your_grok_key_here"

# ===== APP URL =====
VITE_APP_URL="http://localhost:3000"

