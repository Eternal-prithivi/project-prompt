{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:e2e": "vite --port=3100 --host=127.0.0.1 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint": "npm run typecheck && npm run lint:eslint",
    "check:continuity": "node scripts/check-continuity.mjs",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.34.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@eslint/js": "^9.39.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "crypto-js": "^4.2.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "msw": "^2.11.6",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.46.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
